<Window x:Class="APPingSoft_II.Sistema.Home"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Home" Height="700" Width="1280"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- NAVBAR -->
        <Border Grid.Row="0" Background="#FF0138E2">
            <Grid Margin="20,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="37*"/>
                    <RowDefinition Height="23*"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Logo -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Top" Margin="0,15,15,0" Grid.RowSpan="2">
                    <Border Width="30" Height="30" Margin="0,0,8,0">
                        <Rectangle>
                            <Rectangle.Fill>
                                <ImageBrush ImageSource="/Imagenes/logo.png"
                                            Stretch="UniformToFill"
                                            Viewbox="0.23,0.23,0.54,0.54"
                                            ViewboxUnits="RelativeToBoundingBox"/>
                            </Rectangle.Fill>
                        </Rectangle>
                    </Border>
                    <TextBlock Text="Evaluacion de Curso" FontSize="13" FontWeight="Bold"
                               Foreground="White" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Separador -->
                <Rectangle Width="1" Fill="#AAAACC" Margin="171,10,0,10" Grid.ColumnSpan="2" Grid.RowSpan="2"/>

                <!-- Links -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Top" Margin="15,22,15,0" Grid.RowSpan="2">
                    <TextBlock Text="Home" FontSize="12" Foreground="White" Margin="10,0" VerticalAlignment="Center" Cursor="Hand"
                               MouseLeftButtonDown="IrHome" FontWeight="Bold"/>
                    <TextBlock x:Name="navGestionProgramas" Text="Gestion de programas" FontSize="12" Foreground="White"
                               Margin="10,0" Cursor="Hand"
                               MouseLeftButtonDown="IrGestionProgramas" FontWeight="Bold"/>
                    <TextBlock x:Name="navParticipantes" Text="Gestionar participantes" FontSize="12" Foreground="White"
                               Margin="10,0" Cursor="Hand"
                               MouseLeftButtonDown="IrParticipantes" FontWeight="Bold"/>
                    <TextBlock x:Name="navGestionInscripciones" Text="Gestion de Inscripciones" FontSize="12" Foreground="White"
                               Margin="10,0" Cursor="Hand"
                               MouseLeftButtonDown="IrGestionInscripciones" FontWeight="Bold"/>
                    <TextBlock x:Name="navGestionEvaluaciones" Text="Gestion de Evaluaciones" FontSize="12" Foreground="White"
                               Margin="10,0" Cursor="Hand"
                               MouseLeftButtonDown="IrGestionEvaluaciones" FontWeight="Bold"/>
                    <TextBlock Text="Registrar Resultados" FontSize="12" Foreground="White" Margin="10,0" Cursor="Hand"
                               MouseLeftButtonDown="IrRegistrarResultados" FontWeight="Bold"/>
                    <TextBlock Text="Reportes y Metricas" FontSize="12" Foreground="White"
                               Margin="10,0" Cursor="Hand"
                               MouseLeftButtonDown="IrReportes" FontWeight="Bold"/>
                    <TextBlock x:Name="navGestionUsuarios" Text="Gestion de Usuarios" FontSize="12" Foreground="White"
                               Margin="10,0" Cursor="Hand"
                               MouseLeftButtonDown="IrGestionUsuarios" FontWeight="Bold"/>
                </StackPanel>

                <!-- Cerrar Sesión -->
                <Border Grid.Column="4" CornerRadius="6" Width="140" Height="42" Cursor="Hand"
                        Grid.RowSpan="2" MouseLeftButtonDown="BtnCerrarSesion_Click">
                    <TextBlock Text="Cerrar Sesión" Foreground="White" FontSize="13" FontWeight="SemiBold"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
            </Grid>
        </Border>

        <!-- CONTENIDO -->
        <Border Grid.Row="1" Padding="40">
            <Border.Background>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="White" Offset="1"/>
                    <GradientStop Color="#FF0138E2" Offset="0"/>
                </LinearGradientBrush>
            </Border.Background>
            <Border Background="White" CornerRadius="16" Padding="40">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Bienvenida dinámica -->
                    <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,20">
                        <TextBlock x:Name="lblBienvenida" Text="Bienvenido" FontSize="22" FontWeight="Bold"
                                   Foreground="#2D2D2D" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="lblRol" Text="" FontSize="14" Foreground="#888888"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>

                    <!-- Imagen principal -->
                    <StackPanel Grid.Row="1" Orientation="Horizontal"
                                HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Image Source="/Imagenes/Caras.jpg" Stretch="Uniform" MaxHeight="1000" Width="1297" Height="512"/>
                    </StackPanel>

                    <TextBlock Grid.Row="2" Text="Sistema Planificador de Evaluación de Capacitaciones"
                               FontSize="18" FontWeight="SemiBold"
                               Foreground="#2D2D2D" HorizontalAlignment="Center" Margin="0,20,0,0"/>
                </Grid>
            </Border>
        </Border>
    </Grid>
</Window>
