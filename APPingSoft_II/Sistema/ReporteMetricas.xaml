<Window x:Class="APPingSoft_II.Sistema.ReporteMetricas"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Reportes y Métricas" Height="700" Width="1280"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- NAVBAR -->
        <Border Grid.Row="0" Background="#FF0138E2">
            <Grid Margin="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,15,0">
                    <Image Source="/Imagenes/logo.png" Width="150" Height="150" 
                           VerticalAlignment="Center" Margin="0,0,8,0"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                    <TextBlock Text="Evaluacion de Curso" FontSize="13" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>
                </StackPanel>
                <Rectangle Grid.Column="1" Width="1" Fill="#AAAACC" Margin="0,10"/>
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="15,0">
                    <TextBlock Text="Home" FontSize="12" Foreground="White" Margin="10,0" Cursor="Hand"
                            MouseLeftButtonDown="IrHome"/>
                    <TextBlock Text="Gestion de programas" FontSize="12" Foreground="White" Margin="10,0" Cursor="Hand"
                            MouseLeftButtonDown="IrGestionProgramas"/>
                    <TextBlock Text="Gestion de Evaluaciones" FontSize="12" Foreground="White" Margin="10,0" Cursor="Hand"
                            MouseLeftButtonDown="IrGestionEvaluaciones"/>
                    <TextBlock Text="Registrar Resultados" FontSize="12" Foreground="White" Margin="10,0" Cursor="Hand"
                            MouseLeftButtonDown="IrRegistrarResultados"/>
                    <TextBlock Text="Reportes y Metricas" FontSize="12" Foreground="White" Margin="10,0" Cursor="Hand"
                            MouseLeftButtonDown="IrReportes"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- CONTENIDO -->
        <Border Grid.Row="1" Padding="60,50">
            <Border.Background>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="#FF0138E2"/>
                    <GradientStop Color="White" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">

                <!-- Reporte 1 -->
                <Border Margin="20,0" Width="280" CornerRadius="16"
                        BorderBrush="#9090AA" BorderThickness="1.5">
                    <Border.Effect>
                        <DropShadowEffect Color="Gray" BlurRadius="8" Opacity="0.2"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="60"/>
                            <RowDefinition Height="300"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Background="#D8DCF0" CornerRadius="14,14,0,0">
                            <TextBlock Text="Reporte 1" FontSize="20" FontWeight="Bold"
                                       Foreground="#1A1A2E" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <Border Grid.Row="1" Background="White" CornerRadius="0,0,14,14" Padding="20,30">
                           
                        </Border>
                    </Grid>
                </Border>

                <!-- Reporte 2 -->
                <Border Margin="20,0" Width="280" CornerRadius="16"
                        BorderBrush="#9090AA" BorderThickness="1.5">
                    <Border.Effect>
                        <DropShadowEffect Color="Gray" BlurRadius="8" Opacity="0.2"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="60"/>
                            <RowDefinition Height="300"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Background="#8B9DC3" CornerRadius="14,14,0,0">
                            <TextBlock Text="Reporte 2" FontSize="20" FontWeight="Bold"
                                       Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <Border Grid.Row="1" Background="White" CornerRadius="0,0,14,14" Padding="20,30">

                        </Border>
                    </Grid>
                </Border>

                <!-- Reporte 3 -->
                <Border Margin="20,0" Width="280" CornerRadius="16"
                        BorderBrush="#9090AA" BorderThickness="1.5">
                    <Border.Effect>
                        <DropShadowEffect Color="Gray" BlurRadius="8" Opacity="0.2"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="60"/>
                            <RowDefinition Height="300"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Background="#2D3561" CornerRadius="14,14,0,0">
                            <TextBlock Text="Reporte 3" FontSize="20" FontWeight="Bold"
                                       Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <Border Grid.Row="1" Background="White" CornerRadius="0,0,14,14" Padding="20,30">
                           
                        </Border>
                    </Grid>
                </Border>

            </StackPanel>
        </Border>
    </Grid>
</Window>

