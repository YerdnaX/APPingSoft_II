<Window x:Class="APPingSoft_II.Sistema.ReporteMetricas"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Reportes y Métricas" Height="800" Width="1280"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized">

    <Window.Resources>
        <Style x:Key="FormCombo" TargetType="ComboBox">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Background" Value="#F0F0F0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
        </Style>
        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Width" Value="120"/>
            <Setter Property="Background" Value="#3D4A6B"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- NAVBAR -->
        <Border Grid.Row="0">
            <Border.Background>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="#FF0006E8" Offset="0.62"/>
                    <GradientStop Color="White" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid Margin="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,15,0">
                    <Border Width="34" Height="34" Margin="0,0,8,0">
                        <Rectangle>
                            <Rectangle.Fill>
                                <ImageBrush ImageSource="/Imagenes/logo.png"
                                            Stretch="UniformToFill"
                                            Viewbox="0.23,0.23,0.54,0.54"
                                            ViewboxUnits="RelativeToBoundingBox"/>
                            </Rectangle.Fill>
                        </Rectangle>
                    </Border>
                    <TextBlock Text="Evaluacion de Curso" FontSize="13" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                </StackPanel>
                <Rectangle Grid.Column="1" Width="1" Fill="#AAAACC" Margin="0,10"/>
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="15,0">
                    <TextBlock Text="Home" FontSize="12" Foreground="White" Margin="10,0" Cursor="Hand"
                               MouseLeftButtonDown="IrHome" FontWeight="Bold"/>
                    <TextBlock x:Name="navGestionProgramas" Text="Gestion de programas" FontSize="12" Foreground="White" Margin="10,0" Cursor="Hand"
                               MouseLeftButtonDown="IrGestionProgramas" FontWeight="Bold"/>
                    <TextBlock x:Name="navParticipantes" Text="Gestionar participantes" FontSize="12" Foreground="White" Margin="10,0" Cursor="Hand"
                               MouseLeftButtonDown="IrParticipantes" FontWeight="Bold"/>
                    <TextBlock x:Name="navGestionEvaluaciones" Text="Gestion de Evaluaciones" FontSize="12" Foreground="White" Margin="10,0" Cursor="Hand"
                               MouseLeftButtonDown="IrGestionEvaluaciones" FontWeight="Bold"/>
                    <TextBlock Text="Registrar Resultados" FontSize="12" Foreground="White" Margin="10,0" Cursor="Hand"
                               MouseLeftButtonDown="IrRegistrarResultados" FontWeight="Bold"/>
                    <TextBlock Text="Reportes y Metricas" FontSize="12" Foreground="White" Margin="10,0" Cursor="Hand"
                               MouseLeftButtonDown="IrReportes" FontWeight="Bold"/>
                    <TextBlock x:Name="navGestionUsuarios" Text="Gestion de Usuarios" FontSize="12" Foreground="White"
                               Margin="10,0" Cursor="Hand" MouseLeftButtonDown="IrGestionUsuarios" FontWeight="Bold"/>
                </StackPanel>

                <Border Grid.Column="3" CornerRadius="6" Width="140" Height="42" Cursor="Hand"
                        MouseLeftButtonDown="BtnCerrarSesion_Click">
                    <TextBlock Text="Cerrar Sesión" Foreground="White" FontSize="13" FontWeight="SemiBold"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
            </Grid>
        </Border>

        <!-- CONTENIDO -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Background="#F5F7FF">
            <Grid Margin="40,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Título -->
                <TextBlock Grid.Row="0" Text="Reportes y Métricas" FontSize="28" FontWeight="Bold"
                           Foreground="#FF413E3E" HorizontalAlignment="Center" Margin="0,0,0,16"/>

                <!-- Filtros -->
                <Border Grid.Row="1" Background="#F5F5F5" CornerRadius="8" Padding="16,12" Margin="0,0,0,20">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Filtrar por Programa:" VerticalAlignment="Center"
                                   FontSize="13" FontWeight="Bold" Foreground="#555" Margin="0,0,8,0"/>
                        <ComboBox x:Name="cmbFiltroPrograma" Style="{StaticResource FormCombo}" Width="220"
                                  DisplayMemberPath="Nombre" SelectedValuePath="ProgramaId"
                                  SelectionChanged="CmbFiltroPrograma_SelectionChanged"/>
                        <TextBlock Text="Filtrar por Curso:" VerticalAlignment="Center"
                                   FontSize="13" FontWeight="Bold" Foreground="#555" Margin="0,0,8,0"/>
                        <ComboBox x:Name="cmbFiltroCurso" Style="{StaticResource FormCombo}" Width="220"
                                  DisplayMemberPath="Nombre" SelectedValuePath="CursoId"
                                  SelectionChanged="CmbFiltroCurso_SelectionChanged"/>
                        <Button Content="Filtrar" Style="{StaticResource ActionBtn}" Click="BtnFiltrar_Click"/>
                        <Button Content="Limpiar" Style="{StaticResource ActionBtn}"
                                Background="#888888" Click="BtnLimpiarFiltros_Click"/>
                    </StackPanel>
                </Border>

                <!-- Etiqueta de filtro activo -->
                <Border Grid.Row="2" x:Name="pnlFiltroActivo" Background="#EEF2FF" CornerRadius="6"
                        Padding="12,6" Margin="0,0,0,12" Visibility="Collapsed">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Mostrando: " FontSize="12" FontWeight="SemiBold" Foreground="#3D4A6B"/>
                        <TextBlock x:Name="lblFiltroActivo" FontSize="12" Foreground="#3D4A6B"/>
                    </StackPanel>
                </Border>

                <!-- KPI Cards -->
                <Grid Grid.Row="3" Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Participantes -->
                    <Border Grid.Column="0" Background="#3D4A6B" CornerRadius="10" Margin="0,0,8,0" Padding="20,18">
                        <StackPanel>
                            <TextBlock x:Name="kpiParticipantes" Text="—" FontSize="38" FontWeight="Bold"
                                       Foreground="White" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="lblKpiParticipantes" Text="Participantes" FontSize="12" Foreground="#A8B8D8"
                                       HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Evaluaciones -->
                    <Border Grid.Column="1" Background="#FF0138E2" CornerRadius="10" Margin="4,0,4,0" Padding="20,18">
                        <StackPanel>
                            <TextBlock x:Name="kpiEvaluaciones" Text="—" FontSize="38" FontWeight="Bold"
                                       Foreground="White" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="lblKpiEvaluaciones" Text="Evaluaciones" FontSize="12" Foreground="#BBCCEE"
                                       HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Promedio General -->
                    <Border Grid.Column="2" Background="#1E8449" CornerRadius="10" Margin="4,0,4,0" Padding="20,18">
                        <StackPanel>
                            <TextBlock x:Name="kpiPromedio" Text="—" FontSize="38" FontWeight="Bold"
                                       Foreground="White" HorizontalAlignment="Center"/>
                            <TextBlock Text="Promedio General" FontSize="12" Foreground="#A9DFBF"
                                       HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- % Aprobación -->
                    <Border Grid.Column="3" Background="#8B9DC3" CornerRadius="10" Margin="8,0,0,0" Padding="20,18">
                        <StackPanel>
                            <TextBlock x:Name="kpiAprobacion" Text="—" FontSize="38" FontWeight="Bold"
                                       Foreground="White" HorizontalAlignment="Center"/>
                            <TextBlock Text="% Aprobación" FontSize="12" Foreground="#E0E8F8"
                                       HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Gráficos y Tablas -->
                <Grid Grid.Row="4">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Gráficos -->
                    <Grid Grid.Row="0" Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Gráfico: Promedio por Curso -->
                        <Border Grid.Column="0" Background="#F8F9FC" CornerRadius="10" Margin="0,0,8,0"
                                BorderBrush="#E0E0E0" BorderThickness="1" Padding="16,14">
                            <StackPanel>
                                <TextBlock Text="Promedio por Curso" FontSize="14" FontWeight="Bold"
                                           Foreground="#3D4A6B" Margin="0,0,0,12"/>
                                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" Height="180">
                                    <ItemsControl x:Name="icChartCurso">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" Height="180"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Width="68" Margin="6,0" VerticalAlignment="Bottom">
                                                    <TextBlock Text="{Binding ValueText}" FontSize="10" FontWeight="SemiBold"
                                                               HorizontalAlignment="Center" Foreground="#555" Margin="0,0,0,4"/>
                                                    <Border CornerRadius="3,3,0,0" HorizontalAlignment="Center" Width="44"
                                                            Height="{Binding BarHeight}"
                                                            Background="{Binding Fill}"/>
                                                    <TextBlock Text="{Binding Label}" FontSize="9" TextWrapping="Wrap"
                                                               HorizontalAlignment="Center" MaxWidth="66"
                                                               TextAlignment="Center" Foreground="#666" Margin="0,5,0,0"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                                <TextBlock x:Name="lblSinDatoCurso" Text="Sin datos disponibles" FontSize="12"
                                           Foreground="#AAAAAA" HorizontalAlignment="Center" Margin="0,30,0,0"
                                           Visibility="Collapsed"/>
                            </StackPanel>
                        </Border>

                        <!-- Gráfico: Métricas por Programa -->
                        <Border x:Name="pnlGraficoPrograma" Grid.Column="1" Background="#F8F9FC" CornerRadius="10" Margin="8,0,0,0"
                                BorderBrush="#E0E0E0" BorderThickness="1" Padding="16,14">
                            <StackPanel>
                                <TextBlock Text="Promedio por Programa" FontSize="14" FontWeight="Bold"
                                           Foreground="#3D4A6B" Margin="0,0,0,12"/>
                                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" Height="180">
                                    <ItemsControl x:Name="icChartPrograma">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" Height="180"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Width="80" Margin="6,0" VerticalAlignment="Bottom">
                                                    <TextBlock Text="{Binding ValueText}" FontSize="10" FontWeight="SemiBold"
                                                               HorizontalAlignment="Center" Foreground="#555" Margin="0,0,0,4"/>
                                                    <Border CornerRadius="3,3,0,0" HorizontalAlignment="Center" Width="52"
                                                            Height="{Binding BarHeight}"
                                                            Background="{Binding Fill}"/>
                                                    <TextBlock Text="{Binding Label}" FontSize="9" TextWrapping="Wrap"
                                                               HorizontalAlignment="Center" MaxWidth="78"
                                                               TextAlignment="Center" Foreground="#666" Margin="0,5,0,0"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                                <TextBlock x:Name="lblSinDatoPrograma" Text="Sin datos disponibles" FontSize="12"
                                           Foreground="#AAAAAA" HorizontalAlignment="Center" Margin="0,30,0,0"
                                           Visibility="Collapsed"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Tablas detalladas -->
                    <TabControl Grid.Row="1" Background="White" BorderBrush="#DDDDDD" MinHeight="320">

                        <!-- Tab 1: Resultados detallados -->
                        <TabItem Header="Resultados Detallados" FontSize="13" FontWeight="SemiBold">
                            <DataGrid x:Name="dgResultadosDetallados" AutoGenerateColumns="False"
                                      CanUserAddRows="False" IsReadOnly="True"
                                      BorderBrush="#CCCCCC" BorderThickness="1"
                                      GridLinesVisibility="All" Background="White"
                                      RowBackground="White" AlternatingRowBackground="#F9F9F9"
                                      HeadersVisibility="All" RowHeight="40" MaxHeight="400">
                                <DataGrid.ColumnHeaderStyle>
                                    <Style TargetType="DataGridColumnHeader">
                                        <Setter Property="Background" Value="#FF0041E5"/>
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="Height" Value="40"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="Padding" Value="8,0"/>
                                    </Style>
                                </DataGrid.ColumnHeaderStyle>
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Participante" Binding="{Binding Participante}" Width="160"/>
                                    <DataGridTextColumn Header="Programa" Binding="{Binding Programa}" Width="*"/>
                                    <DataGridTextColumn Header="Curso" Binding="{Binding Curso}" Width="150"/>
                                    <DataGridTextColumn Header="Evaluación" Binding="{Binding Evaluacion}" Width="*"/>
                                    <DataGridTextColumn Header="Tipo" Binding="{Binding TipoEvaluacion}" Width="100"/>
                                    <DataGridTextColumn Header="Pts. Máx" Binding="{Binding PuntosMax}" Width="80"/>
                                    <DataGridTextColumn Header="Nota Final" Binding="{Binding NotaFinal}" Width="90"/>
                                    <DataGridTextColumn Header="% Logrado" Binding="{Binding PorcentajeLogrado, StringFormat=N2}" Width="90"/>
                                    <DataGridTextColumn Header="Calificado En" Binding="{Binding CalificadoEn, StringFormat=dd/MM/yyyy}" Width="110"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </TabItem>

                        <!-- Tab 2: Métricas por Curso -->
                        <TabItem Header="Métricas por Curso" FontSize="13" FontWeight="SemiBold">
                            <DataGrid x:Name="dgMetricasCurso" AutoGenerateColumns="False"
                                      CanUserAddRows="False" IsReadOnly="True"
                                      BorderBrush="#CCCCCC" BorderThickness="1"
                                      GridLinesVisibility="All" Background="White"
                                      RowBackground="White" AlternatingRowBackground="#F9F9F9"
                                      HeadersVisibility="All" RowHeight="40" MaxHeight="400">
                                <DataGrid.ColumnHeaderStyle>
                                    <Style TargetType="DataGridColumnHeader">
                                        <Setter Property="Background" Value="#8B9DC3"/>
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="Height" Value="40"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="Padding" Value="8,0"/>
                                    </Style>
                                </DataGrid.ColumnHeaderStyle>
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Código" Binding="{Binding Codigo}" Width="90"/>
                                    <DataGridTextColumn Header="Curso" Binding="{Binding Curso}" Width="*"/>
                                    <DataGridTextColumn Header="Total Evaluaciones" Binding="{Binding TotalEvaluaciones}" Width="140"/>
                                    <DataGridTextColumn Header="Total Resultados" Binding="{Binding TotalResultados}" Width="130"/>
                                    <DataGridTextColumn Header="Promedio Nota" Binding="{Binding PromedioNota, StringFormat=N2}" Width="120"/>
                                    <DataGridTextColumn Header="% Aprobación" Binding="{Binding PorcentajeAprobacion, StringFormat=N2}" Width="120"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </TabItem>

                        <!-- Tab 3: Métricas por Programa (solo Admin y Coordinador) -->
                        <TabItem x:Name="tabMetricasPrograma" Header="Métricas por Programa" FontSize="13" FontWeight="SemiBold">
                            <DataGrid x:Name="dgMetricasPrograma" AutoGenerateColumns="False"
                                      CanUserAddRows="False" IsReadOnly="True"
                                      BorderBrush="#CCCCCC" BorderThickness="1"
                                      GridLinesVisibility="All" Background="White"
                                      RowBackground="White" AlternatingRowBackground="#F9F9F9"
                                      HeadersVisibility="All" RowHeight="40" MaxHeight="400">
                                <DataGrid.ColumnHeaderStyle>
                                    <Style TargetType="DataGridColumnHeader">
                                        <Setter Property="Background" Value="#8B9DC3"/>
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="Height" Value="40"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="Padding" Value="8,0"/>
                                    </Style>
                                </DataGrid.ColumnHeaderStyle>
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Programa" Binding="{Binding Programa}" Width="*"/>
                                    <DataGridTextColumn Header="Estado" Binding="{Binding Estado}" Width="100"/>
                                    <DataGridTextColumn Header="Total Inscritos" Binding="{Binding TotalInscritos}" Width="120"/>
                                    <DataGridTextColumn Header="Resultados Reg." Binding="{Binding ResultadosRegistrados}" Width="130"/>
                                    <DataGridTextColumn Header="Promedio General" Binding="{Binding PromedioGeneral, StringFormat=N2}" Width="140"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </TabItem>

                    </TabControl>
                </Grid>
            </Grid>
        </ScrollViewer>
    </Grid>
</Window>
