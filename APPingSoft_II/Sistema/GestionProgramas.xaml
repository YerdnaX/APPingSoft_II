<Window x:Class="APPingSoft_II.Sistema.GestionProgramas"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Gestión de Programas" Height="700" Width="1280"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized">

    <Window.Resources>
        <Style x:Key="FormLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#888888"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>
        <Style x:Key="FormInput" TargetType="TextBox">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Background" Value="#F0F0F0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="Margin" Value="0,0,0,18"/>
        </Style>
        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Width" Value="140"/>
            <Setter Property="Background" Value="#3D4A6B"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- NAVBAR -->
        <Border Grid.Row="0" Background="#FF0138E2">
            <Grid Margin="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,15,0">
                    <Image Source="/Imagenes/logo.png" Width="150" Height="150" 
                           VerticalAlignment="Center" Margin="0,0,8,0"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                    <TextBlock Text="Evaluacion de Curso" FontSize="13" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>
                </StackPanel>
                <Rectangle Grid.Column="1" Width="1" Fill="#AAAACC" Margin="0,10"/>
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="15,0">
                    <TextBlock Text="Home" FontSize="12" Foreground="White" Margin="10,0" Cursor="Hand"
                            MouseLeftButtonDown="IrHome"/>
                    <TextBlock Text="Gestion de programas" FontSize="12" Foreground="White" Margin="10,0" Cursor="Hand"
                            MouseLeftButtonDown="IrGestionProgramas"/>
                    <TextBlock Text="Gestion de Evaluaciones" FontSize="12" Foreground="White" Margin="10,0" Cursor="Hand"
                            MouseLeftButtonDown="IrGestionEvaluaciones"/>
                    <TextBlock Text="Registrar Resultados" FontSize="12" Foreground="White" Margin="10,0" Cursor="Hand"
                            MouseLeftButtonDown="IrRegistrarResultados"/>
                    <TextBlock Text="Reportes y Metricas" FontSize="12" Foreground="White" Margin="10,0" Cursor="Hand"
                            MouseLeftButtonDown="IrReportes"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- CONTENIDO -->
        <Grid Grid.Row="1" Background="White" Margin="60,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Gestion de programas" FontSize="28" FontWeight="Light"
                       Foreground="#888888" HorizontalAlignment="Center" Margin="0,0,0,40"/>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="320"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Formulario -->
                <StackPanel Grid.Column="0" Margin="0,0,60,0">
                    <TextBlock Text="CREAR PROGRAMA" Style="{StaticResource FormLabel}"/>
                    <TextBox Style="{StaticResource FormInput}"/>

                    <TextBlock Text="CURSOS" Style="{StaticResource FormLabel}"/>
                    <TextBox Style="{StaticResource FormInput}"/>

                    <TextBlock Text="INSTRUCTOR" Style="{StaticResource FormLabel}"/>
                    <TextBox Style="{StaticResource FormInput}"/>

                    <TextBlock Text="OBJETIVO" Style="{StaticResource FormLabel}"/>
                    <TextBox Style="{StaticResource FormInput}" Height="60" 
                             VerticalContentAlignment="Top" Padding="10,8"/>

                    <StackPanel Margin="0,20,0,0">
                        <StackPanel Orientation="Vertical">
                            <Button Content="Ingresar" Style="{StaticResource ActionBtn}" Margin="0,0,0,10"/>
                            <Button Content="Modificar" Style="{StaticResource ActionBtn}" Margin="0,0,0,10"/>
                            <Button Content="Borrar" Style="{StaticResource ActionBtn}" Margin="0,0,0,10"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <!-- Tabla -->
                <DataGrid Grid.Column="1" AutoGenerateColumns="False" CanUserAddRows="False"
                          IsReadOnly="True" BorderBrush="#333333" BorderThickness="1"
                          GridLinesVisibility="All" Background="White"
                          RowBackground="White" AlternatingRowBackground="White"
                          HeadersVisibility="All" RowHeight="45">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#8B9DC3"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="Height" Value="45"/>
                            <Setter Property="FontWeight" Value="Normal"/>
                            <Setter Property="BorderBrush" Value="#333333"/>
                            <Setter Property="BorderThickness" Value="0,0,1,1"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="" Width="*"/>
                        <DataGridTextColumn Header="" Width="*"/>
                        <DataGridTextColumn Header="" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Grid>
    </Grid>
</Window>

