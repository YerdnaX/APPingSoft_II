<Window x:Class="APPingSoft_II.Sistema.GestionProgramas"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Gestión de Programas" Height="850" Width="1280"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized">

    <Window.Resources>
        <Style x:Key="FormLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#888888"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>
        <Style x:Key="FormInput" TargetType="TextBox">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Background" Value="#F0F0F0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,0,18"/>
        </Style>
        <Style x:Key="FormCombo" TargetType="ComboBox">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Background" Value="#F0F0F0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="Margin" Value="0,0,0,18"/>
        </Style>
        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Width" Value="140"/>
            <Setter Property="Background" Value="#3D4A6B"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- NAVBAR -->
        <Border Grid.Row="0" Background="#FF0138E2">
            <Grid Margin="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,15,0">
                    <Border Width="34" Height="34" Margin="0,0,8,0">
                        <Rectangle>
                            <Rectangle.Fill>
                                <ImageBrush ImageSource="/Imagenes/logo.png"
                                            Stretch="UniformToFill"
                                            Viewbox="0.23,0.23,0.54,0.54"
                                            ViewboxUnits="RelativeToBoundingBox"/>
                            </Rectangle.Fill>
                        </Rectangle>
                    </Border>
                    <TextBlock Text="Evaluacion de Curso" FontSize="13" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>
                </StackPanel>
                <Rectangle Grid.Column="1" Width="1" Fill="#AAAACC" Margin="0,10"/>
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="15,0">
                    <TextBlock Text="Home" FontSize="12" Foreground="White" Margin="10,0" Cursor="Hand"
                               MouseLeftButtonDown="IrHome"/>
                    <TextBlock x:Name="navGestionProgramas" Text="Gestion de programas" FontSize="12" Foreground="White" Margin="10,0" Cursor="Hand"
                               MouseLeftButtonDown="IrGestionProgramas"/>
                    <TextBlock x:Name="navParticipantes" Text="Gestionar participantes" FontSize="12" Foreground="White" Margin="10,0" Cursor="Hand"
                               MouseLeftButtonDown="IrParticipantes"/>
                    <TextBlock x:Name="navGestionEvaluaciones" Text="Gestion de Evaluaciones" FontSize="12" Foreground="White" Margin="10,0" Cursor="Hand"
                               MouseLeftButtonDown="IrGestionEvaluaciones"/>
                    <TextBlock Text="Registrar Resultados" FontSize="12" Foreground="White" Margin="10,0" Cursor="Hand"
                               MouseLeftButtonDown="IrRegistrarResultados"/>
                    <TextBlock Text="Reportes y Metricas" FontSize="12" Foreground="White" Margin="10,0" Cursor="Hand"
                               MouseLeftButtonDown="IrReportes"/>
                    <TextBlock x:Name="navGestionUsuarios" Text="Gestion de Usuarios" FontSize="12" Foreground="White"
                               Margin="10,0" Cursor="Hand" MouseLeftButtonDown="IrGestionUsuarios"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- CONTENIDO -->
        <Grid Grid.Row="1" Background="White" Margin="60,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Gestion de Programas" FontSize="28" FontWeight="Light"
                       Foreground="#888888" HorizontalAlignment="Center" Margin="0,0,0,30"/>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="320"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Formulario -->
                <StackPanel Grid.Column="0" Margin="0,0,60,0">

                    <TextBlock Text="NOMBRE DEL PROGRAMA" Style="{StaticResource FormLabel}"/>
                    <TextBox x:Name="txtNombre" Style="{StaticResource FormInput}"/>

                    <TextBlock Text="FECHA INICIO" Style="{StaticResource FormLabel}"/>
                    <DatePicker x:Name="dpFechaInicio" Height="40" Background="#F0F0F0"
                                BorderThickness="0" FontSize="13" Margin="0,0,0,18"/>

                    <TextBlock Text="FECHA FIN" Style="{StaticResource FormLabel}"/>
                    <DatePicker x:Name="dpFechaFin" Height="40" Background="#F0F0F0"
                                BorderThickness="0" FontSize="13" Margin="0,0,0,18"/>

                    <TextBlock Text="ESTADO" Style="{StaticResource FormLabel}"/>
                    <ComboBox x:Name="cmbEstado" Style="{StaticResource FormCombo}">
                        <ComboBoxItem Content="Activo"/>
                        <ComboBoxItem Content="Inactivo"/>
                        <ComboBoxItem Content="Finalizado"/>
                    </ComboBox>

                    <TextBlock Text="INSTRUCTOR" Style="{StaticResource FormLabel}"/>
                    <ComboBox x:Name="cmbInstructor" Style="{StaticResource FormCombo}"
                              DisplayMemberPath="NombreCompleto"
                              SelectedValuePath="InstructorId"/>

                    <TextBlock Text="CURSO" Style="{StaticResource FormLabel}"/>
                    <ComboBox x:Name="cmbCurso" Style="{StaticResource FormCombo}"
                              DisplayMemberPath="Nombre"
                              SelectedValuePath="CursoId"/>

                    <!-- Botones -->
                    <StackPanel Orientation="Vertical" Margin="0,20,0,0">
                        <Button x:Name="btnIngresar" Content="Ingresar" Style="{StaticResource ActionBtn}"
                                Margin="0,0,0,10" Click="BtnIngresar_Click"/>
                        <Button x:Name="btnModificar" Content="Modificar" Style="{StaticResource ActionBtn}"
                                Margin="0,0,0,10" Click="BtnModificar_Click"/>
                        <Button x:Name="btnBorrar" Content="Borrar" Style="{StaticResource ActionBtn}"
                                Margin="0,0,0,10" Click="BtnBorrar_Click"/>
                    </StackPanel>
                </StackPanel>

                <!-- Tabla con búsqueda -->
                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Barra de búsqueda -->
                    <Grid Grid.Row="0" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="#F0F0F0" CornerRadius="6" Margin="0,0,8,0">
                            <TextBox x:Name="txtBuscar" Background="Transparent" BorderThickness="0"
                                     FontSize="13" Padding="10,0" Height="40"
                                     VerticalContentAlignment="Center"
                                     KeyDown="TxtBuscar_KeyDown"/>
                        </Border>
                        <Button Grid.Column="1" Content="Buscar" Width="120" Height="40"
                                Background="#3D4A6B" Foreground="White" FontSize="13"
                                FontWeight="SemiBold" BorderThickness="0" Cursor="Hand"
                                Margin="0,0,8,0" Click="BtnBuscar_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button Grid.Column="2" Content="Ver todos" Width="120" Height="40"
                                Background="#888888" Foreground="White" FontSize="13"
                                FontWeight="SemiBold" BorderThickness="0" Cursor="Hand"
                                Click="BtnVerTodos_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>

                    <!-- Tabla -->
                    <DataGrid x:Name="dgProgramas" Grid.Row="1" AutoGenerateColumns="False"
                              SelectionChanged="DgProgramas_SelectionChanged"
                              CanUserAddRows="False" IsReadOnly="True"
                              BorderBrush="#333333" BorderThickness="1"
                              GridLinesVisibility="All" Background="White"
                              RowBackground="White" AlternatingRowBackground="#F9F9F9"
                              HeadersVisibility="All" RowHeight="45">
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#8B9DC3"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="Height" Value="45"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="BorderBrush" Value="#333333"/>
                                <Setter Property="BorderThickness" Value="0,0,1,1"/>
                                <Setter Property="Padding" Value="10,0"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding ProgramaId}" Width="60"/>
                            <DataGridTextColumn Header="Nombre" Binding="{Binding Nombre}" Width="*"/>
                            <DataGridTextColumn Header="Fecha Inicio" Binding="{Binding FechaInicio, StringFormat=dd/MM/yyyy}" Width="120"/>
                            <DataGridTextColumn Header="Fecha Fin" Binding="{Binding FechaFin, StringFormat=dd/MM/yyyy}" Width="120"/>
                            <DataGridTextColumn Header="Estado" Binding="{Binding Estado}" Width="100"/>
                            <DataGridTextColumn Header="Instructor" Binding="{Binding Instructor.NombreCompleto}" Width="160"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Window>


