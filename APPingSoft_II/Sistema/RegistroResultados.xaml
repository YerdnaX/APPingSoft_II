<Window x:Class="APPingSoft_II.Sistema.RegistroResultados"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Registros de Resultados" Height="800" Width="1280"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized">

    <Window.Resources>
        <Style x:Key="FormLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#888888"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>
        <Style x:Key="FormInput" TargetType="TextBox">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Background" Value="#F0F0F0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,0,18"/>
        </Style>
        <Style x:Key="FormCombo" TargetType="ComboBox">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Background" Value="#F0F0F0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="Margin" Value="0,0,0,18"/>
        </Style>
        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Width" Value="140"/>
            <Setter Property="Background" Value="#3D4A6B"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- NAVBAR -->
        <Border Grid.Row="0" Background="#FF0138E2">
            <Grid Margin="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,15,0">
                    <Border Width="34" Height="34" Margin="0,0,8,0">
                        <Rectangle>
                            <Rectangle.Fill>
                                <ImageBrush ImageSource="/Imagenes/logo.png"
                                            Stretch="UniformToFill"
                                            Viewbox="0.23,0.23,0.54,0.54"
                                            ViewboxUnits="RelativeToBoundingBox"/>
                            </Rectangle.Fill>
                        </Rectangle>
                    </Border>
                    <TextBlock Text="Evaluacion de Curso" FontSize="13" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>
                </StackPanel>
                <Rectangle Grid.Column="1" Width="1" Fill="#AAAACC" Margin="0,10"/>
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="15,0">
                    <TextBlock Text="Home" FontSize="12" Foreground="White" Margin="10,0" Cursor="Hand"
                               MouseLeftButtonDown="IrHome"/>
                    <TextBlock x:Name="navGestionProgramas" Text="Gestion de programas" FontSize="12" Foreground="White" Margin="10,0" Cursor="Hand"
                               MouseLeftButtonDown="IrGestionProgramas"/>
                    <TextBlock x:Name="navParticipantes" Text="Gestionar participantes" FontSize="12" Foreground="White" Margin="10,0" Cursor="Hand"
                               MouseLeftButtonDown="IrParticipantes"/>
                    <TextBlock x:Name="navGestionEvaluaciones" Text="Gestion de Evaluaciones" FontSize="12" Foreground="White" Margin="10,0" Cursor="Hand"
                               MouseLeftButtonDown="IrGestionEvaluaciones"/>
                    <TextBlock Text="Registrar Resultados" FontSize="12" Foreground="White" Margin="10,0" Cursor="Hand"
                               MouseLeftButtonDown="IrRegistrarResultados"/>
                    <TextBlock Text="Reportes y Metricas" FontSize="12" Foreground="White" Margin="10,0" Cursor="Hand"
                               MouseLeftButtonDown="IrReportes"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- CONTENIDO -->
        <Grid Grid.Row="1" Background="White" Margin="60,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Registros de Resultados" FontSize="28" FontWeight="Light"
                       Foreground="#888888" HorizontalAlignment="Center" Margin="0,0,0,30"/>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="320"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Formulario -->
                <StackPanel Grid.Column="0" Margin="0,0,60,0">

                    <TextBlock Text="EVALUACIÓN" Style="{StaticResource FormLabel}"/>
                    <ComboBox x:Name="cmbEvaluacion" Style="{StaticResource FormCombo}"
                              DisplayMemberPath="Titulo"
                              SelectionChanged="CmbEvaluacion_SelectionChanged"/>
                    <TextBlock Text="PARTICIPANTE" Style="{StaticResource FormLabel}"/>
                    <ComboBox x:Name="cmbInscripcion" Style="{StaticResource FormCombo}"
                              DisplayMemberPath="Participante.NombreCompleto"
                              SelectedValuePath="InscripcionId"/>


                    <TextBlock Text="NOTA FINAL" Style="{StaticResource FormLabel}"/>
                    <TextBox x:Name="txtNotaFinal" Style="{StaticResource FormInput}"/>

                    <TextBlock Text="CALIFICADO EN" Style="{StaticResource FormLabel}"/>
                    <TextBox x:Name="txtCalificadoEn" Style="{StaticResource FormInput}"
                             IsReadOnly="True" Foreground="#AAAAAA"
                             Text="{Binding Path=., RelativeSource={RelativeSource Self}}"
                             ToolTip="Se asigna automáticamente al registrar"/>

                    <TextBlock Text="OBSERVACIONES" Style="{StaticResource FormLabel}"/>
                    <TextBox x:Name="txtObservaciones" Style="{StaticResource FormInput}"
                             Height="70" VerticalContentAlignment="Top" Padding="10,8"
                             TextWrapping="Wrap" AcceptsReturn="True"/>

                    <!-- Botones -->
                    <StackPanel Orientation="Vertical" Margin="0,20,0,0">
                        <Button x:Name="btnIngresar" Content="Ingresar" Style="{StaticResource ActionBtn}"
                                Margin="0,0,0,10" Click="BtnIngresar_Click"/>
                        <Button x:Name="btnModificar" Content="Modificar" Style="{StaticResource ActionBtn}"
                                Margin="0,0,0,10" Click="BtnModificar_Click"/>
                        <Button x:Name="btnBorrar" Content="Borrar" Style="{StaticResource ActionBtn}"
                                Margin="0,0,0,10" Click="BtnBorrar_Click"/>
                    </StackPanel>
                </StackPanel>

                <!-- Tabla -->
                <DataGrid x:Name="dgResultados" Grid.Column="1" AutoGenerateColumns="False"
                          SelectionChanged="DgResultados_SelectionChanged"
                          CanUserAddRows="False" IsReadOnly="True"
                          BorderBrush="#333333" BorderThickness="1"
                          GridLinesVisibility="All" Background="White"
                          RowBackground="White" AlternatingRowBackground="#F9F9F9"
                          HeadersVisibility="All" RowHeight="45">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#8B9DC3"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="Height" Value="45"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="BorderBrush" Value="#333333"/>
                            <Setter Property="BorderThickness" Value="0,0,1,1"/>
                            <Setter Property="Padding" Value="10,0"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding ResultadoId}" Width="60"/>
                        <DataGridTextColumn Header="Participante" Binding="{Binding Inscripcion.Participante.NombreCompleto}" Width="*"/>
                        <DataGridTextColumn Header="Evaluación" Binding="{Binding Evaluacion.Titulo}" Width="*"/>
                        <DataGridTextColumn Header="Nota Final" Binding="{Binding NotaFinal}" Width="100"/>
                        <DataGridTextColumn Header="Calificado En" Binding="{Binding CalificadoEn, StringFormat=dd/MM/yyyy HH:mm}" Width="140"/>
                        <DataGridTextColumn Header="Observaciones" Binding="{Binding Observaciones}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Grid>
    </Grid>
</Window>

