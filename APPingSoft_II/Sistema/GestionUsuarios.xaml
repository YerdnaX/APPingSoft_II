<Window x:Class="APPingSoft_II.Sistema.GestionUsuarios"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Gestión de Usuarios" Height="850" Width="1280"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized">


    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- NAVBAR -->
        <Border Grid.Row="0">
            <Border.Background>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="White" Offset="1"/>
                    <GradientStop Color="#FF0006E8" Offset="0.629"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid Margin="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,15,0">
                    <Border Width="34" Height="34" Margin="0,0,8,0">
                        <Rectangle>
                            <Rectangle.Fill>
                                <ImageBrush ImageSource="/Imagenes/logo.png"
                                            Stretch="UniformToFill"
                                            Viewbox="0.23,0.23,0.54,0.54"
                                            ViewboxUnits="RelativeToBoundingBox"/>
                            </Rectangle.Fill>
                        </Rectangle>
                    </Border>
                    <TextBlock Text="Evaluacion de Curso" FontSize="13" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                </StackPanel>
                <Rectangle Grid.Column="1" Width="1" Fill="#AAAACC" Margin="0,10"/>
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="15,0">
                    <TextBlock Text="Home" FontSize="12" Foreground="White" Margin="10,0" Cursor="Hand"
                               MouseLeftButtonDown="IrHome" FontWeight="Bold"/>
                    <TextBlock x:Name="navGestionProgramas" Text="Gestion de programas" FontSize="12" Foreground="White" Margin="10,0" Cursor="Hand"
                               MouseLeftButtonDown="IrGestionProgramas" FontWeight="Bold"/>
                    <TextBlock x:Name="navParticipantes" Text="Gestionar participantes" FontSize="12" Foreground="White" Margin="10,0" Cursor="Hand"
                               MouseLeftButtonDown="IrParticipantes" FontWeight="Bold"/>
                    <TextBlock x:Name="navGestionEvaluaciones" Text="Gestion de Evaluaciones" FontSize="12" Foreground="White" Margin="10,0" Cursor="Hand"
                               MouseLeftButtonDown="IrGestionEvaluaciones" FontWeight="Bold"/>
                    <TextBlock Text="Registrar Resultados" FontSize="12" Foreground="White" Margin="10,0" Cursor="Hand"
                               MouseLeftButtonDown="IrRegistrarResultados" FontWeight="Bold"/>
                    <TextBlock Text="Reportes y Metricas" FontSize="12" Foreground="White" Margin="10,0" Cursor="Hand"
                               MouseLeftButtonDown="IrReportes" FontWeight="Bold"/>
                    <TextBlock x:Name="navGestionUsuarios" Text="Gestion de Usuarios" FontSize="12" Foreground="White"
                               FontWeight="Bold" Margin="10,0" Cursor="Hand"
                               MouseLeftButtonDown="IrGestionUsuarios"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- CONTENIDO -->
        <Grid Grid.Row="1" Background="#F5F7FF" Margin="60,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Gestion de Usuarios" FontSize="28" FontWeight="Bold"
                       Foreground="#FF413E3E" HorizontalAlignment="Center" Margin="0,0,0,30"/>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="320"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- FORMULARIO -->
                <StackPanel Grid.Column="0" Margin="0,0,60,0">

                    <TextBlock Text="NOMBRE COMPLETO" Style="{StaticResource FormLabel}" Foreground="#FF413E3E"/>
                    <TextBox x:Name="txtNombre" Style="{StaticResource FormInput}"/>

                    <TextBlock Text="CORREO ELECTRÓNICO" Style="{StaticResource FormLabel}" Foreground="#FF413E3E"/>
                    <TextBox x:Name="txtCorreo" Style="{StaticResource FormInput}"/>

                    <TextBlock Text="CONTRASEÑA" Style="{StaticResource FormLabel}" Foreground="#FF413E3E"/>
                    <PasswordBox x:Name="pwdContrasena" Height="40" Background="#F0F0F0"
                                 BorderThickness="0" FontSize="13" Padding="10,0"
                                 VerticalContentAlignment="Center" Margin="0,0,0,4"/>
                    <TextBlock Text="Dejar vacío para conservar contraseña al modificar"
                               FontSize="10" Foreground="#AAAAAA" Margin="0,0,0,14"/>

                    <TextBlock Text="ROL" Style="{StaticResource FormLabel}" Foreground="#FF413E3E"/>
                    <ComboBox x:Name="cmbRol" Style="{StaticResource FormCombo}">
                        <ComboBoxItem Content="Administrador"/>
                        <ComboBoxItem Content="Coordinador"/>
                        <ComboBoxItem Content="Instructor"/>
                    </ComboBox>

                    <TextBlock Text="ESTADO" Style="{StaticResource FormLabel}" Foreground="#FF413E3E"/>
                    <ComboBox x:Name="cmbEstado" Style="{StaticResource FormCombo}">
                        <ComboBoxItem Content="Activo"/>
                        <ComboBoxItem Content="Inactivo"/>
                    </ComboBox>

                    <!-- Botones de acción -->
                    <StackPanel Orientation="Vertical" Margin="0,20,0,0">
                        <Button x:Name="btnIngresar" Content="Ingresar" Style="{StaticResource ActionBtn}"
                                Margin="0,0,0,10" Click="BtnIngresar_Click" Background="#FF0041E5"/>
                        <Button x:Name="btnModificar" Content="Modificar" Style="{StaticResource ActionBtn}"
                                Margin="0,0,0,10" Click="BtnModificar_Click" Background="#FF0041E5"/>
                        <Button x:Name="btnBorrar" Content="Borrar" Style="{StaticResource ActionBtn}"
                                Margin="0,0,0,10" Click="BtnBorrar_Click" Background="#DC2626"/>
                        <Button x:Name="btnLimpiar" Content="Limpiar" Style="{StaticResource ActionBtn}"
                                Margin="0,0,0,10" Background="#888888" Click="BtnLimpiar_Click"/>
                    </StackPanel>

                </StackPanel>

                <!-- LADO DERECHO: búsqueda + tabla -->
                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Barra de búsqueda -->
                    <Grid Grid.Row="0" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="#F0F0F0" CornerRadius="6" Margin="0,0,8,0">
                            <TextBox x:Name="txtBuscar" Background="Transparent" BorderThickness="0"
                                     FontSize="13" Padding="10,0" Height="40"
                                     VerticalContentAlignment="Center"
                                     KeyDown="TxtBuscar_KeyDown"/>
                        </Border>
                        <Button Grid.Column="1" Content="Buscar" Width="120" Height="40"
                                Background="#3D4A6B" Foreground="White" FontSize="13"
                                FontWeight="SemiBold" BorderThickness="0" Cursor="Hand"
                                Margin="0,0,8,0" Click="BtnBuscar_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button Grid.Column="2" Content="Ver todos" Width="120" Height="40"
                                Background="#888888" Foreground="White" FontSize="13"
                                FontWeight="SemiBold" BorderThickness="0" Cursor="Hand"
                                Click="BtnVerTodos_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>

                    <!-- Tabla -->
                    <DataGrid x:Name="dgUsuarios" Grid.Row="1" AutoGenerateColumns="False"
                              CanUserAddRows="False" IsReadOnly="True"
                              BorderBrush="#E2E8F0" BorderThickness="1"
                              GridLinesVisibility="None"
                              Background="White"
                              RowBackground="White"
                              AlternatingRowBackground="#F5F7FF"
                              HeadersVisibility="All"
                              RowHeight="38"
                              ColumnHeaderHeight="44"
                              SelectionChanged="DgUsuarios_SelectionChanged">

                        <DataGrid.Resources>
                            <Style TargetType="DataGridRow">
                                <Setter Property="BorderThickness" Value="0"/>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#D6DFFF"/>
                                        <Setter Property="Foreground" Value="#0033BB"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#EBF0FF"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                            <Style TargetType="DataGridCell">
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Padding" Value="10,0"/>
                                <Setter Property="FontSize" Value="13"/>
                                <Setter Property="Foreground" Value="#413E3E"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="BorderBrush" Value="Transparent"/>
                                        <Setter Property="Foreground" Value="#0033BB"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                            <Style TargetType="DataGridRowHeader">
                                <Setter Property="Width" Value="0"/>
                            </Style>
                        </DataGrid.Resources>

                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#0041E5"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="Height" Value="44"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="FontSize" Value="12"/>
                                <Setter Property="BorderBrush" Value="#1A55FF"/>
                                <Setter Property="BorderThickness" Value="0,0,1,0"/>
                                <Setter Property="Padding" Value="10,0"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="DataGridColumnHeader">
                                            <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                                                <ContentPresenter VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID"               Binding="{Binding UsuarioId}"                                Width="60"/>
                            <DataGridTextColumn Header="Nombre Completo"  Binding="{Binding NombreCompleto}"                          Width="*"/>
                            <DataGridTextColumn Header="Correo"           Binding="{Binding CorreoElectronico}"                       Width="*"/>
                            <DataGridTextColumn Header="Rol"              Binding="{Binding Rol}"                                     Width="120"/>
                            <DataGridTextColumn Header="Estado"           Binding="{Binding Estado}"                                  Width="90"/>
                            <DataGridTextColumn Header="Fecha Registro"   Binding="{Binding FechaCreacion, StringFormat=dd/MM/yyyy}"  Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>

            </Grid>
        </Grid>
    </Grid>
</Window>
