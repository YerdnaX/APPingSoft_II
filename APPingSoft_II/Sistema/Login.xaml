<Window x:Class="APPingSoft_II.Sistema.Login"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Login" Height="600" Width="1000"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Lado izquierdo azul -->
        <Border Grid.Column="0">
            <Border.Background>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="#FF325CFF"/>
                    <GradientStop Color="White" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <StackPanel VerticalAlignment="Top" HorizontalAlignment="Left" Margin="30,30,0,0">
                <!-- Logo -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,60">
                    <Border Width="40" Height="40" Margin="0,0,10,0">
                        <Grid>
                            <Rectangle Fill="#FF0024E9" Width="18" Height="18" 
                                       HorizontalAlignment="Left" VerticalAlignment="Top"/>
                            <Rectangle Fill="#2D3561" Width="18" Height="18" 
                                       HorizontalAlignment="Right" VerticalAlignment="Bottom"/>
                        </Grid>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Evaluaciones" FontSize="16" FontWeight="Bold" Foreground="#1A1A2E"/>
                        <TextBlock Text="de Cursos" FontSize="16" FontWeight="Bold" Foreground="#1A1A2E"/>
                    </StackPanel>
                </StackPanel>
                <Image Source="/Imagenes/evaluacion.png" Width="320" Height="320" Stretch="Uniform" Margin="56,0,57,0"/>


                <!-- Ilustración placeholder -->
            </StackPanel>
        </Border>

        <!-- Lado derecho blanco -->
        <Border Grid.Column="1" Background="White">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="380">
                <TextBlock Text="¡Bienvenido de nuevo!" FontSize="28" FontWeight="Bold"
                           Foreground="Black" HorizontalAlignment="Center" Margin="0,0,0,40"/>

                <!-- Correo -->
                <Border BorderBrush="#C0C0C0" BorderThickness="1.5" CornerRadius="6" Margin="0,0,0,16">
                    <TextBox Text="Correo electrónico" Foreground="#AAAAAA"
                             Background="Transparent" BorderThickness="0"
                             FontSize="14" Padding="15,12" Height="50"/>
                </Border>

                <!-- Contraseña -->
                <Border BorderBrush="#C0C0C0" BorderThickness="1.5" CornerRadius="6" Margin="0,0,0,25">
                    <Grid>
                        <PasswordBox Foreground="#AAAAAA" Background="Transparent"
                                     BorderThickness="0" FontSize="14" Padding="15,12" Height="50"/>
                        <TextBlock Text="Contraseña" Foreground="#AAAAAA" FontSize="14"
                                   VerticalAlignment="Center" Margin="15,0,0,0" IsHitTestVisible="False"/>
                        <TextBlock Text="👁" FontSize="16" HorizontalAlignment="Right"
                                   VerticalAlignment="Center" Margin="0,0,15,0"/>
                    </Grid>
                </Border>

                <!-- Botón -->
                <Button Content="Iniciar sesión" Height="52" FontSize="16" FontWeight="Bold"
                        Background="#5C6BC0" Foreground="White" BorderThickness="0"
                        Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="#5C6BC0" CornerRadius="25">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <TextBlock Text="Recordar contraseña" Foreground="#333333" FontSize="13"
                           TextDecorations="Underline" Margin="0,20,0,8" Cursor="Hand"/>
                <TextBlock FontSize="13" Foreground="#333333">
                    <Run Text="¿Todavía no tienes una cuenta? "/>
                    <Run Text="Regístrate" TextDecorations="Underline" Foreground="#333333"/>
                </TextBlock>
            </StackPanel>
        </Border>
    </Grid>
</Window>
