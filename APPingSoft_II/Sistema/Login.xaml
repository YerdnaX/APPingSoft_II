<Window x:Class="APPingSoft_II.Sistema.Login"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Login" Height="600" Width="1000"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Lado izquierdo azul -->
        <Border Grid.Column="0">
            <Border.Background>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="#FF325CFF"/>
                    <GradientStop Color="White" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <StackPanel VerticalAlignment="Top" HorizontalAlignment="Left" Margin="30,30,0,0">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,60">
                    <Border Width="40" Height="40" Margin="0,0,10,0">
                        <Grid>
                            <Rectangle Fill="#FF0024E9" Width="18" Height="18"
                                       HorizontalAlignment="Left" VerticalAlignment="Top"/>
                            <Rectangle Fill="#2D3561" Width="18" Height="18"
                                       HorizontalAlignment="Right" VerticalAlignment="Bottom"/>
                        </Grid>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Evaluaciones" FontSize="16" FontWeight="Bold" Foreground="#1A1A2E"/>
                        <TextBlock Text="de Cursos" FontSize="16" FontWeight="Bold" Foreground="#1A1A2E"/>
                    </StackPanel>
                </StackPanel>
                <Image Source="/Imagenes/evaluacion.png" Width="320" Height="320" Stretch="Uniform" Margin="56,0,57,0"/>
            </StackPanel>
        </Border>

        <!-- Lado derecho blanco -->
        <Border Grid.Column="1" Background="White">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="380">
                <TextBlock Text="¡Bienvenido de nuevo!" FontSize="28" FontWeight="Bold"
                           Foreground="Black" HorizontalAlignment="Center" Margin="0,0,0,40"/>

                <!-- Correo -->
                <Border BorderBrush="#C0C0C0" BorderThickness="1.5" CornerRadius="6" Margin="0,0,0,16">
                    <TextBox x:Name="txtCorreo" FontSize="14" Padding="15,12" Height="50"
                             Background="Transparent" BorderThickness="0"
                             Foreground="#333333" VerticalContentAlignment="Center"
                             KeyDown="TxtCorreo_KeyDown"/>
                </Border>

                <!-- Contraseña -->
                <Border BorderBrush="#C0C0C0" BorderThickness="1.5" CornerRadius="6" Margin="0,0,0,10">
                    <Grid>
                        <PasswordBox x:Name="pwdContrasena" Foreground="#333333" Background="Transparent"
                                     BorderThickness="0" FontSize="14" Padding="15,12" Height="50"
                                     KeyDown="PwdContrasena_KeyDown"/>
                        <TextBox x:Name="txtContrasenaVisible" Foreground="#333333" Background="Transparent"
                                 BorderThickness="0" FontSize="14" Padding="15,12" Height="50"
                                 Visibility="Collapsed" VerticalContentAlignment="Center"/>
                        <TextBlock x:Name="lblToggleIcon" Text="👁" FontSize="16" HorizontalAlignment="Right"
                                   VerticalAlignment="Center" Margin="0,0,15,0" Cursor="Hand"
                                   MouseLeftButtonDown="BtnTogglePassword_MouseLeftButtonDown"/>
                    </Grid>
                </Border>

                <!-- Mensaje de error -->
                <TextBlock x:Name="lblError" Foreground="Red" FontSize="12" TextWrapping="Wrap"
                           Margin="0,0,0,10" Visibility="Collapsed"/>

                <!-- Botón -->
                <Button Content="Iniciar sesión" Height="42" FontSize="13" FontWeight="SemiBold"
                        Background="#5C6BC0" Foreground="White" BorderThickness="0"
                        Cursor="Hand" Click="BtnIniciarSesion_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="#5C6BC0" CornerRadius="6">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

            </StackPanel>
        </Border>
    </Grid>
</Window>
